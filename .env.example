# Digital Utopia Configuration

# Anthropic API
ANTHROPIC_API_KEY=your-api-key-here

# World Settings
UTOPIA_ROOT=./worlds
DEFAULT_TOKEN_BUDGET=1000

# Agent Settings
AGENT_LOOP_INTERVAL_MS=5000
AGENT_REST_DURATION_MS=60000
MAX_ACTIONS_PER_CYCLE=3

# LLM Settings
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7

# Observer Dashboard
DASHBOARD_PORT=3000
WEBSOCKET_PORT=3001

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
